{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Frontend: Chrome Debug",
            "type": "chrome",
            "request": "launch",
            "url": "http://localhost:5173",
            "webRoot": "${workspaceFolder}/frontend",
            "sourceMapPathOverrides": {
                "webpack:///src/*": "${webRoot}/src/*"
            },
            "userDataDir": "${workspaceFolder}/.vscode/chrome-debug-profile",
            "runtimeArgs": [
                "--disable-web-security"
            ]
        },
        {
            "name": "Frontend: Edge Debug",
            "type": "msedge",
            "request": "launch",
            "url": "http://localhost:5173",
            "webRoot": "${workspaceFolder}/frontend",
            "sourceMapPathOverrides": {
                "webpack:///src/*": "${webRoot}/src/*"
            },
            "userDataDir": "${workspaceFolder}/.vscode/edge-debug-profile"
        },
        {
            "name": "Gin Server",
            "type": "go",
            "request": "launch",
            "mode": "auto",
            "program": "${workspaceFolder}/go_backend",
            "cwd": "${workspaceFolder}/go_backend",
            "env": {
                "PORT": "8080"
            }
        },
        {
            "name": "Gin (Embedded)",
            "type": "go",
            "request": "launch",
            "mode": "auto",
            "program": "${workspaceFolder}/go_backend",
            "cwd": "${workspaceFolder}/go_backend",
            "buildFlags": "-tags=embed",
            "env": {
                "PORT": "8080"
            }
        },
        {
            "name": "FastAPI Server (Windows)",
            "type": "debugpy",
            "request": "launch",
            "module": "uvicorn",
            "args": [
                "main:app",
                "--host",
                "0.0.0.0",
                "--port",
                "8000",
                "--reload"
            ],
            "cwd": "${workspaceFolder}/backend",
            "python": "${workspaceFolder}/.venv/Scripts/python.exe",
            "env": {
                "PORT": "8000",
                "DB_PATH": "./rack_switch.db"
            },
            "console": "integratedTerminal",
            "justMyCode": false
        },
        {
            "name": "FastAPI Server (Linux/macOS)",
            "type": "debugpy",
            "request": "launch",
            "module": "uvicorn",
            "args": [
                "main:app",
                "--host",
                "0.0.0.0",
                "--port",
                "8000",
                "--reload",
                "--debug"
            ],
            "cwd": "${workspaceFolder}/backend",
            "python": "${workspaceFolder}/.venv/bin/python",
            "env": {
                "PORT": "8000",
                "DB_PATH": "./rack_switch.db"
            },
            "console": "integratedTerminal",
            "justMyCode": false
        }
    ]
}